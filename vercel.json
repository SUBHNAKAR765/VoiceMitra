{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rootDirectory": "frontend",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://voicemitra-production.up.railway.app/api/:path*"
    },
    {
      "source": "/audio/:path*",
      "destination": "https://voicemitra-production.up.railway.app/audio/:path*"
    },
    {
      "source": "/health",
      "destination": "https://voicemitra-production.up.railway.app/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
